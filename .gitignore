node_modules
.env
backend/node_modules
values.local.yaml

# Terraform
# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data
*.tfvars
*.tfvars.json

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Include plugin cache directory (optional: some prefer to commit this)
# .terraform.lock.hcl

# Ignore the .terraformrc file
.terraformrc
terraform.rc
